{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "ready_for_translation": {
      "type": "boolean"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          },
          "file": {
            "type": "string"
          },
          "issue": {
            "type": "string"
          },
          "recommendation": {
            "type": "string"
          }
        },
        "required": ["severity", "file", "issue", "recommendation"]
      }
    }
  },
  "required": ["ready_for_translation", "findings"]
}
